# Vorte Middleware Environment Variables
# Copy to .env and fill in values

# Google Gemini API Key (REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here

# Server
PORT=3000
NODE_ENV=production

# Auth - Accepted device token prefixes (comma-separated)
ALLOWED_TOKEN_PREFIX=vrt_

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Logging
LOG_LEVEL=info
